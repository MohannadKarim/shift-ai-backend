APP_ENV=development
DEBUG=true

# Firebase — use ONE of:
# Option A: path to credentials file (local dev)
FIREBASE_CREDENTIALS_PATH=firebase-credentials.json
# Option B: full JSON as string (production — use this for Fly.io secrets)
FIREBASE_CREDENTIALS_JSON=

# Anthropic Claude API key
ANTHROPIC_API_KEY=sk-ant-...

# CORS — your frontend origin
ALLOWED_ORIGINS=["http://localhost:5173","https://shift-ai-frontend.fly.dev"]

# Super admin email
SUPER_ADMIN_EMAIL=asayeh@telfaz11.com

# Max tokens per user per day
DAILY_TOKEN_BUDGET=50000
